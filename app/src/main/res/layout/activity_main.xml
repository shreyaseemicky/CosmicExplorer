<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT — pure black sky, no camera -->
    <FrameLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000010">

        <!-- ✨ Star map fills entire screen -->
        <com.example.cosmicexplorer.SkyOverlayView
            android:id="@+id/skyOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Horizon gradient at bottom — makes it feel like Stellarium -->
        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:background="@drawable/horizon_gradient"/>

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="top"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <!-- ☰ Menu top left -->
            <ImageButton
                android:id="@+id/menuBtn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_btn_bg"
                android:src="@android:drawable/ic_menu_more"
                android:contentDescription="Menu"/>

            <!-- 🧭 Compass center -->
            <TextView
                android:id="@+id/compassText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="#AACCDEFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:text="N  0°  ↕0°"/>

            <!-- 🔍 Search top right -->
            <EditText
                android:id="@+id/searchBar"
                android:layout_width="160dp"
                android:layout_height="40dp"
                android:background="@drawable/search_bg"
                android:hint="🔍 Search..."
                android:textColor="#FFFFFF"
                android:textColorHint="#88FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="13sp"
                android:inputType="text"
                android:imeOptions="actionSearch"/>

            <!-- 🔴 Night mode -->
            <ImageButton
                android:id="@+id/nightModeBtn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/circle_btn_bg"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="Night mode"/>
        </LinearLayout>

        <!-- Cardinal directions at horizon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="30dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="W"
                android:textColor="#66AADDFF"
                android:textSize="13sp"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="S"
                android:textColor="#66AADDFF"
                android:textSize="13sp"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="E"
                android:textColor="#66AADDFF"
                android:textSize="13sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

    </FrameLayout>

    <!-- LEFT DRAWER — unchanged -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#EE050A1A"
        android:orientation="vertical"
        android:paddingTop="48dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✦ COSMIC EXPLORER"
            android:textColor="#FFAADDFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:paddingStart="20dp"
            android:paddingBottom="16dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33AADDFF"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  🌏  SKY CULTURES"
            android:textColor="#88AADDFF"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:paddingStart="16dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/drawerContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33AADDFF"/>

        <TextView
            android:id="@+id/exitBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="  ✕   Exit"
            android:textColor="#FF6666"
            android:textSize="15sp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>